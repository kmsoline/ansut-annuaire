generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id        Int     @id @default(autoincrement())
  nom       String?
  fonction  String?
  extension String?
  contact   String?
  email     String?
  photo     String?
  direction String?
  site      String?
  manager   String?
  favoris   Boolean @default(false)
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  passwordHash String
  role         String  @default("user")
  favorites    Int[]   @default([])
}

model Site {
  id      String  @id
  name    String
  address String  @default("")
  lat     Float
  lng     Float
  color   String  @default("#1d4ed8")
  image   String? @default("")
}

model Log {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  adminEmail String
  action     String
  target     String
  details    String?
}
