# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Shared password for all @ansut.ci accounts (legacy fallback)
AUTH_PASSWORD="your-shared-password"

# Admin account (bypass DB — always works even without DB)
ADMIN_EMAILS="admin@example.com"
ADMIN_PASSWORD="your-admin-password"

# Vercel Blob (get from Vercel dashboard after creating a Blob store)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
